# Centurio — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# ── Supabase (from your Supabase project settings → API) ──────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Google Gemini ─────────────────────────────────────────────────────────────
# The Gemini key is NEVER used by the app/client in V2. It lives only as a
# Supabase Edge Function secret so it can't be extracted from the APK:
#   supabase secrets set GEMINI_API_KEY=your_gemini_api_key_here
# (Do NOT add EXPO_PUBLIC_GEMINI_API_KEY — that would ship the key in the app.)
